digraph G {
    ingress -> nf_0_0;
    ingress -> nf_0_1;

    nf_0_0 -> nf_1_0;
    nf_0_0 -> nf_1_1;
    nf_0_0 -> nf_1_2;


    nf_0_1 -> nf_1_0;
    nf_0_1 -> nf_1_2;

    nf_0_1 -> nf_1_3; // synthetic passthrough induced by type system?

    nf_1_0 -> nf_2_0;
    nf_1_1 -> nf_2_0;
    nf_1_3 -> nf_2_0;

    nf_2_0 -> egress;
}


// first stage of compile: NF graph
digraph G {
    ingress -> nf_0_0;
    ingress -> nf_0_1;

    nf_0_0 -> nf_1_0;
    nf_0_0 -> nf_1_1;
    nf_0_0 -> nf_1_2;


    nf_0_1 -> nf_1_0;
    nf_0_1 -> nf_1_2;
    nf_0_1 -> nf_2_0;

    nf_1_0 -> nf_2_0;
    nf_1_1 -> nf_2_0;

    nf_2_0 -> egress;
}
