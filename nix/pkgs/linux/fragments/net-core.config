# Core networking and protocols
#
# The NET option is the top-level menuconfig gate for the entire networking
# subsystem.  Nearly every other networking option (including PACKET, UNIX,
# INET, VSOCKETS, NET_NS, cgroup net options, and all of net/sched) lives
# inside `if NET` in the kernel Kconfig tree.
CONFIG_NET=y

# NETDEVICES is the menuconfig gate for all network device drivers
# (virtual and physical).  Depends on NET.
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y

# Socket types
CONFIG_PACKET=y
CONFIG_UNIX=y

# IPv4
CONFIG_INET=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP_ROUTE_VERBOSE=y
CONFIG_SYN_COOKIES=y
CONFIG_TCP_CONG_CUBIC=y

# IPv6
CONFIG_IPV6=y
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_ROUTE_INFO=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_IPV6_MULTIPLE_TABLES=y

# L2
CONFIG_BRIDGE=y
CONFIG_BRIDGE_VLAN_FILTERING=y
CONFIG_VLAN_8021Q=y

# Misc
CONFIG_VSOCKETS=y
CONFIG_NETLINK_DIAG=y
CONFIG_NET_SWITCHDEV=y
CONFIG_NET_L3_MASTER_DEV=y
CONFIG_ETHTOOL_NETLINK=y
CONFIG_PSAMPLE=y